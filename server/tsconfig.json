{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "rootDir": ".",
        "outDir": "../dist-server",
        "types": ["node"]
    },
    "include": ["**/*.ts", "**/*.d.ts"]
}
