# Public website
PUBLIC_ORIGIN=https://canvas.ikui.cn
WEB_BIND_IP=127.0.0.1
WEB_PORT=8080

# AikArt PostgreSQL
AIKART_DB_NAME=aikart
AIKART_DB_USER=aikart
AIKART_DB_PASSWORD=replace_with_a_long_alphanumeric_password

# 爱坤Ai account and billing database (PostgreSQL)
BILLING_DATABASE_URL=postgresql://newapi_user:encoded_password@host.docker.internal:5432/newapi
AIKUN_AI_QUOTA_PER_UNIT=500000
PLATFORM_ADMIN_AIKUN_USER_ID=1

# Security: generate both with `openssl rand -hex 32`
SESSION_SECRET=replace_with_64_hex_characters
CONTENT_ENCRYPTION_KEY=replace_with_another_64_hex_characters

# Object storage
MINIO_ACCESS_KEY=aikartadmin
MINIO_SECRET_KEY=replace_with_a_minimum_16_character_password
MINIO_BUCKET=aikart-media
MINIO_CONSOLE_PORT=9001

# Retention and backup
DRAFT_RETENTION_DAYS=7
CLEANUP_INTERVAL_MINUTES=360
MAX_UPLOAD_MB=100
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14
