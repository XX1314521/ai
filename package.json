{
    "name": "infinite-canvas",
    "version": "0.1.0",
    "description": "AikArt web creation suite and cross-platform storyboard desktop workstation.",
    "author": "AikArt",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --configLoader runner --host 0.0.0.0 --port 3000",
        "dev:full": "concurrently -k \"npm run server:dev\" \"npm run dev\"",
        "server:dev": "tsx watch server/index.ts",
        "server:build": "tsc -p server/tsconfig.json",
        "server:typecheck": "tsc -p server/tsconfig.json --noEmit",
        "server:start": "node dist-server/index.js",
        "build": "vite build --configLoader runner",
        "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000/desktop.html && electron electron/main.cjs --dev\"",
        "desktop:renderer": "cross-env VITE_DESKTOP=true vite build --configLoader runner",
        "desktop:build": "npm run desktop:build:win",
        "desktop:build:win": "npm run desktop:renderer && electron-builder --win",
        "desktop:build:mac": "npm run desktop:renderer && electron-builder --mac",
        "desktop:build:linux": "npm run desktop:renderer && electron-builder --linux",
        "typecheck": "tsc --noEmit",
        "start": "vite preview --configLoader runner --host 0.0.0.0 --port 3000",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@ant-design/cssinjs": "^2.1.2",
        "@ant-design/icons": "^6.1.1",
        "@ant-design/pro-components": "3.0.0-beta.3",
        "@aws-sdk/client-s3": "^3.1088.0",
        "@codemirror/lang-json": "^6.0.2",
        "@fastify/cookie": "^11.1.1",
        "@fastify/http-proxy": "^11.5.0",
        "@fastify/multipart": "^10.1.0",
        "@fastify/rate-limit": "^11.1.0",
        "@tanstack/react-query": "^5.100.9",
        "@uiw/react-codemirror": "^4.25.9",
        "antd": "^6.4.2",
        "axios": "^1.16.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "copy-to-clipboard": "^4.0.2",
        "dayjs": "^1.11.20",
        "fastify": "^5.10.0",
        "fflate": "^0.8.3",
        "file-saver": "^2.0.5",
        "localforage": "^1.10.0",
        "lucide-react": "^1.16.0",
        "motion": "^12.38.0",
        "nanoid": "^5.1.11",
        "pg": "^8.22.0",
        "radix-ui": "^1.4.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-router": "^7.12.0",
        "react-router-dom": "^7.12.0",
        "shadcn": "^4.7.0",
        "streamdown": "^2.5.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "@types/react": "19.1.12",
        "@types/react-dom": "19.1.9",
        "@vitejs/plugin-react": "^5.2.0",
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "electron": "^39.1.2",
        "electron-builder": "^26.0.12",
        "prettier": "^3.8.3",
        "tsx": "^4.23.1",
        "typescript": "^5",
        "vite": "^7.3.0",
        "wait-on": "^9.0.1"
    },
    "main": "electron/main.cjs",
    "build": {
        "appId": "cn.aikart.storyboard",
        "productName": "AikArt Storyboard",
        "asar": true,
        "electronDist": "node_modules/electron/dist",
        "files": [
            "dist-desktop/**/*",
            "electron/**/*"
        ],
        "directories": {
            "output": "release-storyboard-build"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "artifactName": "AikArt-Storyboard-${version}-${arch}.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "artifactName": "AikArt-Storyboard-${version}-${arch}-Setup.${ext}"
        },
        "portable": {
            "artifactName": "AikArt-Storyboard-${version}-${arch}-Portable.${ext}"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.graphics-design",
            "artifactName": "AikArt-Storyboard-${version}-${arch}.${ext}"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Graphics",
            "artifactName": "AikArt-Storyboard-${version}-${arch}.${ext}"
        }
    }
}
